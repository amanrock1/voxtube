# Server Environment Variables
PORT=5000

# Supabase Credentials (from your Supabase Dashboard settings)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Gemini API Key (from Google AI Studio - completely free)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Developer API Key (for YouTube Data API v3 - free)
YOUTUBE_API_KEY=your_youtube_api_key_here

# (Optional) Your deployed frontend URL — required for CORS in production
# Example: https://voxtube.vercel.app
FRONTEND_URL=

# Shared secret key — must match VITE_API_KEY in client/.env
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLIENT_API_KEY=your_generated_secret_key_here